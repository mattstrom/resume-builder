{
  "name": "@mattstrom/resume-builder",
  "private": true,
  "version": "0.1.0",
  "license": "BUSL-1.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start:mcp": "op run --env-file=.env -- sh -c 'docker compose up -d mcp'",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docker:build": "nx run-many -t docker-build",
    "docker:push": "nx run-many -t docker-push",
    "deploy": "op run --env-file=.env -- sh -c 'helm upgrade ${RELEASE:-resume-builder} charts/resume-builder --namespace ${NAMESPACE:-resume-builder} --set backend.image.tag=${TAG:-latest} --set web.image.tag=${TAG:-latest} --set mongodb.password=${MONGODB_PASSWORD} --install'"
  },
  "workspaces": [
    "packages/backend",
    "packages/entities",
    "packages/resume-builder"
  ],
  "devDependencies": {
    "@nestjs/cli": "^11.0.14",
    "@nx/eslint": "22.6.4",
    "@nx/js": "22.6.4",
    "@nx/storybook": "22.6.4",
    "@nx/vite": "22.6.4",
    "@nx/vitest": "22.6.4",
    "@nx/web": "22.6.4",
    "@storybook/addon-vitest": "^10.3.4",
    "@storybook/react-vite": "10.3.4",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/html2canvas": "^0.5.35",
    "@types/trusted-types": "^2.0.7",
    "@vitest/ui": "^4.0.0",
    "commander": "^14.0.2",
    "del-cli": "^7.0.0",
    "eslint": "~8.57.0",
    "jiti": "2.4.2",
    "nx": "22.6.4",
    "prettier": "3.7.4",
    "storybook": "10.3.4",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2",
    "vite": "^5.2.0",
    "vitest": "^4.0.17",
    "playwright": "^1.59.1",
    "@vitest/browser-playwright": "^4.0.17",
    "@vitest/coverage-v8": "^4.0.17"
  },
  "dependencies": {
    "lightningcss": "^1.30.2"
  }
}
