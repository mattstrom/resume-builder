{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "_id": {},
    "uid": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "company": {
      "type": "string"
    },
    "level": {
      "type": "string"
    },
    "jobPostingUrl": {
      "type": "string"
    },
    "data": {
      "type": "object",
      "properties": {
        "_id": {},
        "name": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "contactInformation": {
          "type": "object",
          "properties": {
            "_id": {},
            "uid": {
              "type": "string"
            },
            "location": {
              "type": "string"
            },
            "phoneNumber": {
              "type": "string"
            },
            "email": {
              "type": "string",
              "format": "email",
              "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
            },
            "linkedInProfile": {
              "type": "string"
            },
            "githubProfile": {
              "type": "string"
            },
            "personalWebsite": {
              "type": "string"
            }
          },
          "required": [
            "_id",
            "uid",
            "location",
            "phoneNumber",
            "email",
            "linkedInProfile",
            "githubProfile",
            "personalWebsite"
          ],
          "additionalProperties": false
        },
        "summary": {
          "type": "string"
        },
        "workExperience": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "_id": {},
              "uid": {
                "type": "string"
              },
              "__v": {
                "type": "number"
              },
              "company": {
                "type": "string"
              },
              "position": {
                "type": "string"
              },
              "location": {
                "type": "string"
              },
              "startDate": {
                "type": "string"
              },
              "endDate": {
                "type": "string"
              },
              "responsibilities": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "relevance": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            },
            "required": [
              "_id",
              "uid",
              "company",
              "position",
              "location",
              "startDate",
              "responsibilities"
            ],
            "additionalProperties": false
          }
        },
        "education": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "_id": {},
              "uid": {
                "type": "string"
              },
              "degree": {
                "type": "string"
              },
              "field": {
                "type": "string"
              },
              "institution": {
                "type": "string"
              },
              "graduated": {
                "type": "string"
              }
            },
            "required": [
              "_id",
              "uid",
              "degree",
              "field",
              "institution",
              "graduated"
            ],
            "additionalProperties": false
          }
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "_id": {},
              "uid": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "category": {
                "type": "string"
              },
              "relevance": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            },
            "required": [
              "_id",
              "uid",
              "name",
              "category"
            ],
            "additionalProperties": false
          }
        },
        "projects": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "_id": {},
              "uid": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "technologies": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "items": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "type": {
                "type": "string",
                "enum": [
                  "professional",
                  "personal"
                ]
              },
              "relevance": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            },
            "required": [
              "_id",
              "uid",
              "name",
              "technologies",
              "items"
            ],
            "additionalProperties": false
          }
        },
        "volunteering": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "_id": {},
              "uid": {
                "type": "string"
              },
              "__v": {
                "type": "number"
              },
              "organization": {
                "type": "string"
              },
              "position": {
                "type": "string"
              },
              "location": {
                "type": "string"
              },
              "startDate": {
                "type": "string"
              },
              "endDate": {
                "type": "string"
              },
              "responsibilities": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "relevance": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            },
            "required": [
              "_id",
              "uid",
              "position",
              "startDate",
              "responsibilities"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "_id",
        "name",
        "title",
        "contactInformation",
        "summary",
        "workExperience",
        "education",
        "skills",
        "projects"
      ],
      "additionalProperties": false
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
    }
  },
  "required": [
    "_id",
    "uid",
    "id",
    "name",
    "company",
    "jobPostingUrl",
    "data",
    "createdAt",
    "updatedAt"
  ],
  "additionalProperties": false
}
