{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"target": "esnext",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"noEmit": false,
		"outDir": "dist",
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"declaration": true,
		"baseUrl": "./src",
		"skipLibCheck": true,
		"strictPropertyInitialization": false,
		"noUnusedLocals": false
	},
	"include": ["./src/**/*.ts"]
}
