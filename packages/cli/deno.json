		"@commander-js/extra-typings": "npm:@commander-js/extra-typings@^12.1.0",
		"@inquirer/core": "npm:@inquirer/core@^10.0.1",
		"@inquirer/prompts": "npm:@inquirer/prompts@^7.0.1",
		"@nestjs/common": "npm:@nestjs/common@^11.0.15",
		"@nestjs/config": "npm:@nestjs/config@^4.0.2",
		"@nestjs/core": "npm:@nestjs/core@^11.0.15",
		"@notionhq/client": "npm:@notionhq/client@3.1.2",
		"@std/assert": "jsr:@std/assert@^1.0.7",
		"@std/cli": "jsr:@std/cli@^1.0.6",
		"@std/fs": "jsr:@std/fs@^1.0.6",
		"@std/path": "jsr:@std/path@^1.0.8",
		"commander": "npm:commander@^12.1.0",
