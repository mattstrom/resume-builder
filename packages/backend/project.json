{
  "$schema": "../../node_modules/nx/schemas/nx-schema.json",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "target": "build",
          "dependencies": true
        }
      ],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "npm run build",
        "cwd": "{projectRoot}"
      }
    }
  }
}
