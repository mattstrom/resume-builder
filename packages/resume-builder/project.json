{
  "$schema": "../../node_modules/nx/schemas/nx-schema.json",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "target": "build",
          "dependencies": true
        }
      ],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "npm run build",
        "cwd": "{projectRoot}"
      }
    },
    "docker-build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -f packages/resume-builder/Dockerfile -t ${REGISTRY:-registry.mattstrom.com}/resume-builder-web:${TAG:-latest} ."
      }
    },
    "docker-push": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker push ${REGISTRY:-registry.mattstrom.com}/resume-builder-web:${TAG:-latest}"
      }
    }
  }
}
