{
  "version": "0.1.0",
  "tasks": {
    "dev": "deno run --watch main.ts"
  },
  "workspace": {
    "members": ["./packages/cli", "./packages/resume-builder"]
  },
  "nodeModulesDir": "auto",
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/expect": "jsr:@std/expect@^1.0.16",
    "@std/testing": "jsr:@std/testing@^1.0.16"
  },
  "allowScripts": [
    "npm:@nestjs/core@11.1.11",
    "npm:esbuild@0.21.5",
    "npm:fsevents@2.3.3"
  ],

  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "fmt": {
    "useTabs": true,
    "indentWidth": 4,
    "singleQuote": true
  }
}
